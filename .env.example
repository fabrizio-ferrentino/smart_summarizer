# ── AI Provider ──────────────────────────────────────────────────────────────
# Choose which AI provider to use: gemini | openai | anthropic  (default: gemini)
AI_PROVIDER="gemini"

# ── Gemini (Google) ───────────────────────────────────────────────────────────
# Required when AI_PROVIDER=gemini
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Required when AI_PROVIDER=openai
# Get your key at: https://platform.openai.com/api-keys
# Supported audio formats: MP3, WAV, WebM  (MP4 not supported)
OPENAI_API_KEY="YOUR_OPENAI_API_KEY"
# OPENAI_MODEL="gpt-4o"   # optional override (default: gpt-4o)

# ── Anthropic (Claude) ────────────────────────────────────────────────────────
# Required when AI_PROVIDER=anthropic
# Note: audio/video upload is NOT supported with this provider
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY="YOUR_ANTHROPIC_API_KEY"
# ANTHROPIC_MODEL="claude-sonnet-4-6"   # optional override

# ── App ───────────────────────────────────────────────────────────────────────
APP_URL="http://localhost:3000"
